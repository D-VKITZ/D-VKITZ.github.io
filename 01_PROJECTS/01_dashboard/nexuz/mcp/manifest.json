{
    "manifest_version": 3,
    "name": "NEXUZ² MCP — DkZ Browser Integration",
    "version": "1.0.0",
    "description": "NEXUZ² Model Context Protocol Extension für Chrome und Vivaldi — Verbindet den Browser mit dem DkZ-Ökosystem",
    "permissions": [
        "sidePanel",
        "contextMenus",
        "storage",
        "activeTab"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "side_panel": {
        "default_path": "sidepanel.html"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        },
        "default_title": "NEXUZ² MCP"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "options_page": "options.html",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}