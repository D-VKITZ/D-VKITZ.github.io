{
  "name": "Ecosystem Analyzer Skills",
  "version": "v1.02.0_01",
  "skills": [
    {
      "id": "compatibility-check",
      "name": "Kompatibilitaets-Check",
      "desc": "Prueft ob Modul ins DkZ Oekosystem passt",
      "actions": ["scan-module", "lint-code", "check-links"],
      "output": "ecosystemScore (0-100)",
      "checks": ["dkz-theme.css", "shared scripts", "hub-link", "nexuz", "james", "chain-nav", "version-meta"]
    },
    {
      "id": "structure-evaluate",
      "name": "Struktur-Bewertung",
      "desc": "Ordner, Dateien, Konventionen pruefen",
      "actions": ["scan-module"],
      "output": "structureReport",
      "checks": ["features.json", "README.md", "index.html", "meta-tags", "shared-scripts"]
    },
    {
      "id": "content-rate",
      "name": "Inhalts-Bewertung",
      "desc": "James GPT + LLM Inhaltskontrolle",
      "actions": ["lint-code"],
      "llm": true,
      "mistral_ocr": true,
      "output": "contentRating",
      "evaluators": ["james-22-rules", "llm-deep-analysis", "mistral-ocr-scan"]
    },
    {
      "id": "auto-fix",
      "name": "Auto-Fix",
      "desc": "Issues erkennen und Fix-Vorschlaege generieren",
      "actions": ["lint-code", "format-code"],
      "llm": true,
      "output": "fixReport",
      "loop": true,
      "maxIterations": 5
    }
  ]
}