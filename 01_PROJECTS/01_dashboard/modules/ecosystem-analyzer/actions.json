{
  "name": "Ecosystem Analyzer Actions",
  "version": "v1.02.0_01",
  "actions": [
    {"id": "scan-module", "name": "Modul scannen", "icon": "folder", "desc": "Dateien, Struktur, Groesse analysieren", "input": "modulePath", "output": "scanResult"},
    {"id": "lint-code", "name": "James Lint", "icon": "search", "desc": "22 Regeln pruefen (Quality/Security/Design/Prompt/Structure/Logic)", "input": "htmlCode", "output": "lintResult"},
    {"id": "check-links", "name": "Verweise pruefen", "icon": "link", "desc": "Alle href/src/import Verweise validieren", "input": "htmlCode", "output": "linkReport"},
    {"id": "generate-docs", "name": "Doku generieren", "icon": "file-text", "desc": "README.md + features.json erstellen", "input": "moduleMeta", "output": "docFiles"},
    {"id": "format-code", "name": "Code formatieren", "icon": "code", "desc": "HTML/JS/CSS Formatierung (Prettier-Logik)", "input": "code", "output": "formattedCode"},
    {"id": "git-create", "name": "GitHub Repo erstellen", "icon": "github", "desc": "Neues Repository via GitHub API anlegen", "input": "repoName", "output": "repoUrl"},
    {"id": "git-push", "name": "Git Push", "icon": "upload", "desc": "Changes committen und pushen", "input": "commitMsg", "output": "pushResult"}
  ]
}