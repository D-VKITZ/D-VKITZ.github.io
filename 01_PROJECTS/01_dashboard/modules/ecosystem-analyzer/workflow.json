{
  "name": "Ecosystem Analysis Pipeline",
  "version": "v1.02.0_01",
  "description": "Vollstaendige Analyse-Pipeline: Scan, Lint, LLM, Fix-Loop, Doku, Git",
  "steps": [
    {"id": 1, "name": "SCAN", "action": "scan-module", "desc": "Dateien erfassen, Struktur analysieren"},
    {"id": 2, "name": "LINT", "skill": "compatibility-check", "desc": "James 22 Regeln + Ecosystem Score pruefen"},
    {"id": 3, "name": "LLM EVAL", "skill": "content-rate", "desc": "Tiefe Bewertung via LLM + Mistral OCR"},
    {"id": 4, "name": "LOOP", "skill": "auto-fix", "type": "loop", "maxIterations": 5, "exitCondition": "score >= 90 || issues == 0",
     "steps": [
       {"id": "4a", "name": "AUTO-FIX", "desc": "Bekanntes Pattern? Fix anwenden"},
       {"id": "4b", "name": "LLM-FIX", "desc": "Fix-Vorschlag via LLM generieren", "fallback": true},
       {"id": "4c", "name": "RE-CHECK", "desc": "James nochmal pruefen"},
       {"id": "4d", "name": "REPORT", "desc": "Ergebnis loggen"}
     ]
    },
    {"id": 5, "name": "DOCUMENT", "action": "generate-docs", "desc": "README + features.json generieren"},
    {"id": 6, "name": "GIT OPS", "action": "git-push", "desc": "Commit, Push, Version bump", "optional": true},
    {"id": 7, "name": "FINAL SCORE", "desc": "Gesamt-Bewertung ausgeben", "output": "analysisReport"}
  ]
}