{
    "module": "n8n-viewer",
    "id": "MOD-083",
    "version": "1.0.0",
    "title": "n8n Workflow Viewer",
    "description": "Visueller n8n Workflow Viewer und Builder mit Drawflow Node-Editor, 3.815+ Template-Browser und Live-Status",
    "author": "DkZ Developer™",
    "created": "2026-03-20",
    "status": "active",
    "portable": true,
    "features": [
        { "id": "F001", "name": "Drawflow Node-Editor", "status": "done", "desc": "ComfyUI-Style Canvas mit Drag & Drop" },
        { "id": "F002", "name": "Template-Browser", "status": "done", "desc": "3.815 n8n Templates durchsuchbar" },
        { "id": "F003", "name": "Tag-Filter", "status": "done", "desc": "Top 12 Tags als Quick-Filter" },
        { "id": "F004", "name": "Volltextsuche", "status": "done", "desc": "Name, Nodes und Tags durchsuchen" },
        { "id": "F005", "name": "Info-Panel", "status": "done", "desc": "Klick auf Node/Workflow zeigt Details" },
        { "id": "F006", "name": "JSON Import/Export", "status": "done", "desc": "n8n und Drawflow Format" },
        { "id": "F007", "name": "Keyboard Shortcuts", "status": "done", "desc": "Ctrl+E Export, Ctrl+I Import, Esc" },
        { "id": "F008", "name": "n8n API Bridge", "status": "planned", "desc": "SSH Tunnel zu KVM 8 n8n" },
        { "id": "F009", "name": "Live-Status", "status": "planned", "desc": "Aktive Workflows anzeigen" },
        { "id": "F010", "name": "Copilot Integration", "status": "planned", "desc": ".n8n Befehl im Copilot" },
        { "id": "F011", "name": "DEEPKEEP Templates", "status": "planned", "desc": "700+ Templates aus Archiven" }
    ],
    "dependencies": {
        "external": ["drawflow@0.0.60"],
        "shared": ["dkz-navbar.js", "dkz-debug.js", "dkz-guide.js", "dkz-crosslinks.js", "dkz-copilot.js"],
        "data": ["../agent-builder/n8n-catalog.json"]
    },
    "servers": {
        "kvm8": { "alias": "n8n-server", "ip": "[HOSTINGER_KVM8_IP]", "role": "n8n Queue Mode" },
        "openclaw": { "alias": "openclaw", "hostname": "srv1368349.hstgr.cloud", "role": "OpenClaw" },
        "test": { "alias": "test-server", "ip": "[HOSTINGER_KVM4_TEST_IP]", "role": "Workflow Tests" }
    }
}
