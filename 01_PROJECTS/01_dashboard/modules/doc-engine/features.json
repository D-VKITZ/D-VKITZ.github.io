{
    "id": "MOD-053",
    "name": "DocEngine",
    "version": "0.01",
    "description": "Allmächtiger Web-Scraper & Wiki-Builder mit Multi-Engine Scraping, DuckDB-Suche, Export-Hub und Publisher-Integration",
    "category": "data",
    "ui": "vanilla",
    "design": {
        "framework": "DkZ Design System v2",
        "theme": "dark/light",
        "accentColor": "#fa1e4e",
        "responsive": true
    },
    "code": {
        "structure": "modular",
        "files": [
            "index.html",
            "app.js",
            "style.css",
            "i18n.js",
            "proxy-server.js",
            "config.ini"
        ],
        "inlineCSS": false,
        "inlineJS": false,
        "localStorage": "docengine-data"
    },
    "i18n": {
        "supported": [
            "en",
            "de"
        ],
        "file": "i18n.js"
    },
    "features": [
        {
            "name": "Multi-Engine Scraping (fetch/proxy/paste)",
            "status": "done"
        },
        {
            "name": "HTML Parser mit Content-Extraktion",
            "status": "done"
        },
        {
            "name": "DuckDB-WASM Suchmaschine",
            "status": "done"
        },
        {
            "name": "Export Hub (JSON/CSV/Markdown/INI)",
            "status": "done"
        },
        {
            "name": "Wiki Browser mit Navigationsbaum",
            "status": "done"
        },
        {
            "name": "CSE Manager (Google Custom Search)",
            "status": "wip"
        },
        {
            "name": "Publisher (Blogger/GitHub/Notion/Drive/SSH)",
            "status": "wip"
        },
        {
            "name": "Theme Toggle (Dark/Light)",
            "status": "done"
        },
        {
            "name": "Keyboard Shortcuts (Ctrl+K/E/Enter/Esc)",
            "status": "done"
        },
        {
            "name": "Activity Log Console",
            "status": "done"
        },
        {
            "name": "ZIP Bundle Export",
            "status": "planned"
        }
    ],
    "issues": [
        {
            "id": "DE-009",
            "severity": "low",
            "description": "CORS Proxies sind externe Dienste — können ausfallen"
        }
