{
  "name": "dkz-security-tools",
  "version": "1.0.0",
  "description": "DkZ Security Scanner + FileManager EXEs",
  "bin": {
    "dkz-scanner": "./dkz-scanner.js",
    "dkz-filemanager": "./dkz-filemanager.js"
  },
  "pkg": {
    "targets": ["node18-win-x64"],
    "outputPath": "dist"
  },
  "scripts": {
    "build": "npx -y pkg . --target node18-win-x64 --output dist/dkz-scanner.exe && npx -y pkg ./dkz-filemanager.js --target node18-win-x64 --output dist/dkz-filemanager.exe",
    "build:scanner": "npx -y pkg ./dkz-scanner.js --target node18-win-x64 --output dist/dkz-scanner.exe",
    "build:filemanager": "npx -y pkg ./dkz-filemanager.js --target node18-win-x64 --output dist/dkz-filemanager.exe",
    "test:scanner": "node dkz-scanner.js",
    "test:filemanager": "node dkz-filemanager.js --desktop"
  }
}
