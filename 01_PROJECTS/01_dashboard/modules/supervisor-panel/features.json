{
  "moduleId": "MOD-090",
  "name": "Supervisor Panel",
  "version": "1.0.0",
  "description": "Live-Monitoring Dashboard für Pi Agent Supervisor, Job Queue, Agent Registry und n8n Workflows",
  "features": [
    "Orchestrator Status (Loops, Engine, Uptime)",
    "Job Queue Visualisierung (Queued/Processing/Failed)",
    "Agent Registry Live-Karten",
    "n8n Bridge Status + Workflow-Übersicht",
    "Event-Log (30 letzte Events)",
    "Steuerung: Start/Pause/Stop/Reset",
    "Auto-Refresh alle 5 Sekunden",
    "DkZ Dark Theme + Glassmorphism"
  ],
  "dependencies": ["ONTHERUN Gateway v3.0", "Pi Agent API", "n8n Bridge"],
  "status": "active"
}
