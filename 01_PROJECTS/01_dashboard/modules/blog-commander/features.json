{
    "id": "MOD-090",
    "name": "Blog Commander",
    "version": "1.0.0",
    "description": "Blogger API Automation Dashboard — 53 Blogs zentral per API steuern",
    "category": "management",
    "status": "active",
    "author": "DkZ Developer™",
    "created": "2026-04-01",
    "tags": ["blogger", "api", "automation", "bulk", "oauth2"],
    "dependencies": {
        "backend": "ONTHERUN Gateway (port 3040)",
        "npm": ["googleapis"],
        "api": "Blogger API v3 (OAuth2)"
    },
    "features": [
        {
            "id": "F001",
            "name": "OAuth2 Google Login",
            "status": "active",
            "description": "Authentifizierung mit Google für Blogger API Zugriff"
        },
        {
            "id": "F002",
            "name": "Blog Dashboard",
            "status": "active",
            "description": "Alle 53 Blogs mit Ampel-Status, Vertical-Filter, Multi-Select"
        },
        {
            "id": "F003",
            "name": "Bulk Post Creator",
            "status": "active",
            "description": "Posts an 1 oder N Blogs gleichzeitig senden"
        },
        {
            "id": "F004",
            "name": "Bulk Page Manager",
            "status": "active",
            "description": "Pages (llms.txt, Impressum) an alle Blogs deployen"
        },
        {
            "id": "F005",
            "name": "Cross-Blog Search",
            "status": "active",
            "description": "Suche über alle 53 Blogs hinweg"
        },
        {
            "id": "F006",
            "name": "Activity Log",
            "status": "active",
            "description": "Echtzeit-Log aller API-Operationen"
        }
    ],
    "endpoints": {
        "auth": "/api/v1/blogger/auth",
        "blogs": "/api/v1/blogger/blogs",
        "posts": "/api/v1/blogger/posts/:blogId",
        "pages": "/api/v1/blogger/pages/:blogId",
        "bulkPosts": "/api/v1/blogger/bulk/posts",
        "bulkPages": "/api/v1/blogger/bulk/pages",
        "search": "/api/v1/blogger/bulk/search"
    }
}
